---
interface Props {
  title?: string;
  description?: string;
  iconColor?: string;
}

const { title, description, iconColor = 'bg-[#2A5B6F]/10' } = Astro.props as Props;
---

<div class="flex flex-col p-8 bg-white/90 rounded-2xl border border-white shadow-sm transition-all duration-300 hover:-translate-y-2 hover:shadow-lg">
  <div class={`w-12 h-12 ${iconColor} rounded-xl mb-6 flex items-center justify-center`}>
    <slot name="icon" />
  </div>

  <h3 class="text-xl font-bold text-[var(--color-text)] mb-3">{title ?? 'Título'}</h3>
  <p class="text-slate-600 leading-snug">{description ?? 'Descrição breve dos valores.'}</p>
</div>

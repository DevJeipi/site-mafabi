---
import type { THeader } from '../types';
import StrapiImage from './StrapiImage.astro';

interface Props {
  data: THeader;
  class?: string;
}

const { data } = Astro.props;
if (!data) return null;

const { logo, Itemsnav, socialLink } = data;
---

<!-- Row 1: Brand / Top Bar -->
<header class={`w-full ${Astro.props.class ?? ''}`}>
  <div class="w-full bg-white h-30 flex items-center justify-between px-6 border-b border-gray-100">
    <!-- Left side: Logo + Text -->
    <div class="flex items-center gap-4 min-w-0">
      {logo?.image ? (
        <a
          href={logo.href}
          target={logo.isExternal ? '_blank' : '_self'}
          rel={logo.isExternal ? 'noopener noreferrer' : undefined}
          class="shrink-0 w-40 h-16 sm:w-50 sm:h-19 rounded-lg overflow-hidden"
        >
          <StrapiImage
            src={logo.image.url}
            alt={logo.image.alternativeText || logo.label}
            width={56}
            height={56}
            aspectRatio="square"
            class="w-full h-full"
          />
        </a>
      ) : (
        <div class="w-14 h-14 rounded-lg bg-gradient-to-br from-teal-500 to-teal-600 flex items-center justify-center flex-shrink-0 overflow-hidden">
          <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z" />
          </svg>
        </div>
      )}
    </div>

    <!-- Right side: LogoLink icon -->
    {socialLink?.image ? (
      <a
        href={socialLink.href}
        target={socialLink.isExternal ? '_blank' : '_self'}
        rel={socialLink.isExternal ? 'noopener noreferrer' : undefined}
        class="flex items-center gap-2 rounded-xl px-2 py-1 hover:bg-gray-50"
      >
        <div class="w-8 h-8 sm:w-10 sm:h-10 rounded-xl overflow-hidden">
          <StrapiImage
            src={socialLink.image.url}
            alt={socialLink.image.alternativeText || socialLink.label}
            width={40}
            height={40}
            aspectRatio="square"
            class="w-full h-full"
          />
        </div>
        <span class="hidden sm:inline text-sm font-medium text-gray-700 truncate">{socialLink.label}</span>
      </a>
    ) : (
      <a
        href={logo?.href}
        target={logo?.isExternal ? '_blank' : '_self'}
        rel={logo?.isExternal ? 'noopener noreferrer' : undefined}
        class="flex items-center gap-2 rounded-xl px-2 py-1 hover:bg-gray-50"
      >
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-teal-500 to-teal-600 flex items-center justify-center">
          <span class="text-white text-sm font-bold">{String(logo?.label?.[0] ?? 'M')}</span>
        </div>
        <span class="hidden sm:inline text-sm font-medium text-gray-700">{logo?.label || '@materiaisadaptadosfabi'}</span>
      </a>
    )}
  </div>

  <!-- Row 2: Navigation Bar -->
  <nav class="w-full bg-gradient-to-r from-teal-600 to-teal-700 flex items-end justify-center px-6 py-4">
    <div class="flex justify-center items-end gap-8 sm:gap-16 w-full max-w-6xl overflow-x-auto">
      {Itemsnav?.map((item) => (
        <a
          href={item.href}
          target={item.isExternal ? '_blank' : '_self'}
          rel={item.isExternal ? 'noopener noreferrer' : undefined}
          class="flex flex-col items-center gap-2 min-h-[72px] min-w-[72px] sm:min-h-[92px] sm:min-w-[90px] hover:opacity-80 transition-opacity"
        >
          <div class="w-16 h-16 rounded-full flex items-center justify-center shadow-md bg-white/10 overflow-hidden">
            {item.image?.url ? (
              <StrapiImage
                src={item.image.url}
                alt={item.image.alternativeText || item.label}
                width={64}
                height={64}
                aspectRatio="square"
                class="w-full h-full"
              />
            ) : (
              <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" />
              </svg>
            )}
          </div>
          <span class="text-[10px] uppercase text-center font-semibold text-black tracking-wide whitespace-nowrap">{item.label}</span>
        </a>
      ))}
    </div>
  </nav>
</header>

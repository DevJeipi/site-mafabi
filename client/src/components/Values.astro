---
import type { TValuesBlock } from '../types';
import ValueCard from './ValueCard.astro';
import {
  Heart,
  Target,
  Shield,
  Lightbulb,
  BookOpen,
  Stethoscope,
  CheckCircle,
  Star,
  Sparkles,
  Smile,
  Globe,
  Brain,
} from 'lucide-react';

interface Props {
  valuesBlock: TValuesBlock;
}

const { valuesBlock } = Astro.props as Props;

const heading = valuesBlock.heading ?? 'Os Pilares';
const description = valuesBlock.description ?? 'Valores que guiam nossas escolhas e sustentam nossa missão.';
const values = valuesBlock.values ?? [];

const valuePastels = [
  'bg-[var(--color-pastel-pink)]',
  'bg-[var(--color-pastel-yellow)]',
  'bg-[var(--color-pastel-purple)]',
  'bg-[var(--color-pastel-blue)]',
];

function iconKey(icon?: string) {
  return (icon ?? '').toLowerCase();
}
---

<section class="py-20 px-4 bg-[var(--color-surface-soft)]" data-reveal>
  <div class="max-w-7xl mx-auto">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-sm uppercase tracking-[0.3em] text-[var(--color-primary-teal)] font-semibold">Valores</p>
      <h2 class="mt-4 text-3xl md:text-4xl font-bold text-[var(--color-text)]">{heading}</h2>
      <p class="mt-4 text-base md:text-lg text-slate-600 leading-relaxed">{description}</p>
    </div>

    <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 gap-6">
      {values.map((v, idx) => (
        <ValueCard title={v.title} description={v.description} iconColor={valuePastels[idx % valuePastels.length]}>
          <div slot="icon">
            {iconKey(v.icon) === 'heart' ? (
              <Heart className="w-6 h-6 text-white" />
            ) : iconKey(v.icon) === 'target' ? (
              <Target className="w-6 h-6 text-white" />
            ) : iconKey(v.icon) === 'shield' ? (
              <Shield className="w-6 h-6 text-white" />
            ) : iconKey(v.icon) === 'lightbulb' ? (
              <Lightbulb className="w-6 h-6 text-white" />
            ) : iconKey(v.icon) === 'bookopen' || iconKey(v.icon) === 'book_open' ? (
              <BookOpen className="w-6 h-6 text-white" />
            ) : iconKey(v.icon) === 'stethoscope' ? (
              <Stethoscope className="w-6 h-6 text-white" />
            ) : iconKey(v.icon) === 'checkcircle' ? (
              <CheckCircle className="w-6 h-6 text-white" />
            ) : iconKey(v.icon) === 'star' ? (
              <Star className="w-6 h-6 text-white" />
            ) : iconKey(v.icon) === 'sparkles' ? (
              <Sparkles className="w-6 h-6 text-white" />
            ) : iconKey(v.icon) === 'smile' ? (
              <Smile className="w-6 h-6 text-white" />
            ) : iconKey(v.icon) === 'globe' ? (
              <Globe className="w-6 h-6 text-white" />
            ) : iconKey(v.icon) === 'brain' ? (
              <Brain className="w-6 h-6 text-white" />
            ) : (
              <svg
                class="w-6 h-6 text-white"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
                <path d="M8 12h8" />
              </svg>
            )}
          </div>
        </ValueCard>
      ))}
    </div>
  </div>
</section>

<script>
  (() => {
    const els = document.querySelectorAll('[data-reveal]');
    if (!els.length) return;
    els.forEach((el) => {
      el.classList.add('opacity-0', 'translate-y-3');
    });
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          e.target.classList.remove('opacity-0', 'translate-y-3');
          e.target.classList.add('opacity-100');
          e.target.classList.add('transition-all', 'duration-700');
          io.unobserve(e.target);
        }
      }
    }, { threshold: 0.12 });
    els.forEach((el) => io.observe(el));
  })();
</script>

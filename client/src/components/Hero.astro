---
// Strapi-connected hero component
import type { THeroBlock } from '../types';
import StrapiImage from './StrapiImage.astro';

interface Props {
  hero: THeroBlock;
}

const { hero } = Astro.props as Props;

let BASE_URL = import.meta.env.VITE_STRAPI_BASE_URL ?? 'http://127.0.0.1:1337';
if (BASE_URL.includes('localhost')) {
  BASE_URL = BASE_URL.replace('localhost', '127.0.0.1');
}

function toMediaUrl(url?: string | null) {
  if (!url) return null;
  if (url.startsWith('http') || url.startsWith('//') || url.startsWith('data:')) return url;
  return `${BASE_URL}${url}`;
}

// Strapi fields:
// - `image` (multi): usamos como background (campo principal no design)
// - `imageAbove`: usamos como imagem principal do lado direito
const heroImage = hero.imageAbove ?? null;
const heroBg = toMediaUrl(hero.image?.[0]?.url) ?? null;

---

<section
  class="relative w-full overflow-hidden"
  style={heroBg ? `background-image: url('${heroBg}'); background-size: cover; background-position: center;` : undefined}
>
  <div class="absolute inset-0 bg-gradient-to-r from-white/85 via-white/40 to-transparent" />
  <div class="absolute inset-0 backdrop-blur-[2px]" />

  <div class="w-full relative max-w-7xl mx-auto px-6 py-16 md:py-24">
    <div class="grid grid-cols-1 md:grid-cols-2 items-center gap-10">
      <div class="z-10">
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-slate-900">{hero.heading}</h1>
        <p class="mt-4 text-base md:text-lg leading-relaxed text-slate-700">
          {hero.text.split('\n').map((line, idx, arr) => (
            <>
              {line}
              {idx < arr.length - 1 ? <br /> : null}
            </>
          ))}
        </p>

        {hero.links?.length ? (
          <div class="mt-8 flex flex-col sm:flex-row gap-3">
            {hero.links.map((l) => (
              <a
                href={l.href}
                target={l.isExternal ? '_blank' : '_self'}
                rel={l.isExternal ? 'noopener noreferrer' : undefined}
                class={
                  l.isButtonLink
                    ? 'inline-flex items-center justify-center rounded-2xl bg-teal-600 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-teal-700'
                    : 'inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white/80 px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-50'
                }
              >
                {l.label}
              </a>
            ))}
          </div>
        ) : null}
      </div>

      <div class="z-10 flex justify-end">
        <div class="rounded-3xl shadow-[0_30px_70px_-35px_rgba(2,6,23,0.35)] overflow-hidden border border-white/60 bg-white/70">
          {heroImage?.url ? (
            <div class="relative w-full h-[260px] md:h-[340px]">
              <StrapiImage
                src={heroImage.url}
                alt={heroImage.alternativeText || hero.heading}
                width={1200}
                height={800}
                aspectRatio="auto"
                class="w-full h-full object-cover"
                quality={90}
              />
            </div>
          ) : (
            <div class="h-[260px] md:h-[340px] flex items-center justify-center text-slate-500">
              <svg
                class="w-10 h-10 text-slate-400"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
                <circle cx="8.5" cy="8.5" r="1.5" />
                <path d="m21 15-5-5L5 21" />
              </svg>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</section>

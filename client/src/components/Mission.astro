---
import type { TMissionBlock } from '../types';

interface Props {
  mission: TMissionBlock;
}

const { mission } = Astro.props as Props;

  const heading = mission.heading ?? 'O Propósito';
  const text = mission.text ?? 'Acreditamos no potencial que a comunicação liberta.';
  const quote = mission.quote ?? 'Onde outros veem barreiras, nós construímos pontes baseadas em altas expectativas.';

---

<section class="py-20 px-4 bg-[var(--color-surface-alt)] text-center" data-reveal>
  <div class="max-w-4xl mx-auto">
    <p class="text-sm uppercase tracking-[0.3em] text-[var(--color-primary-magenta)] font-semibold">Propósito</p>
    <h2 class="mt-4 text-3xl md:text-4xl font-bold text-[var(--color-text)] mb-8 tracking-tight">
      {heading}
    </h2>

  <p class="text-lg md:text-xl text-slate-600 leading-relaxed mb-10 max-w-3xl mx-auto">
    {text.split('\n').map((line, idx) => (
      <>
        {line}
        {idx < text.split('\n').length - 1 ? <br /> : null}
      </>
    ))}
  </p>

    <div class="inline-block p-6 border-l-4 border-[var(--color-primary-magenta)] bg-white/80 shadow-sm italic text-slate-700 rounded-2xl">
      "{quote}"
    </div>
  </div>
</section>

<script>
  (() => {
    const els = document.querySelectorAll('[data-reveal]');
    if (!els.length) return;
    els.forEach((el) => {
      el.classList.add('opacity-0', 'translate-y-3');
    });
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          e.target.classList.remove('opacity-0', 'translate-y-3');
          e.target.classList.add('opacity-100');
          e.target.classList.add('transition-all', 'duration-700');
          io.unobserve(e.target);
        }
      }
    }, { threshold: 0.12 });
    els.forEach((el) => io.observe(el));
  })();
</script>
